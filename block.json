{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "query-forge/builder",
	"title": "Query Forge",
	"category": "widgets",
	"icon": "filter",
	"description": "Visual node-based query builder for displaying posts.",
	"supports": {
		"html": false
	},
	"editorStyle": "file:./assets/css/qf-block-editor.css",
	"textdomain": "query-forge",
	"attributes": {
		"graphState": { "type": "string", "default": "" },
		"logicJson": { "type": "string", "default": "" },
		"columns": { "type": "integer", "default": 3 },
		"cardStyle": { "type": "string", "default": "vertical" },
		"showTitle": { "type": "string", "default": "yes" },
		"showExcerpt": { "type": "string", "default": "yes" },
		"showImage": { "type": "string", "default": "yes" },
		"showDate": { "type": "string", "default": "yes" },
		"showAuthor": { "type": "string", "default": "yes" },
		"excerptLength": { "type": "integer", "default": 100 },
		"imageSize": { "type": "string", "default": "medium" },
		"showPagination": { "type": "string", "default": "no" },
		"paginationType": { "type": "string", "default": "standard" },
		"showResultsSummary": { "type": "string", "default": "no" },
		"columnGap": { "type": "integer", "default": 20 },
		"rowGap": { "type": "integer", "default": 20 },
		"showReadMore": { "type": "string", "default": "yes" },
		"cardButtonPosition": { "type": "string", "default": "bottom" },
		"linkTarget": { "type": "string", "default": "_self" },
		"cardImageRatio": { "type": "string", "default": "16/9" },
		"cardBorderRadius": { "type": "integer", "default": 0 },
		"cardShadow": { "type": "string", "default": "soft" },
		"cardBackgroundColor": { "type": "string", "default": "" },
		"cardTitleColor": { "type": "string", "default": "" },
		"cardMetaColor": { "type": "string", "default": "" },
		"cardExcerptColor": { "type": "string", "default": "" },
		"cardButtonColor": { "type": "string", "default": "" },
		"titleAlign": { "type": "string", "default": "" },
		"titleLinkDecoration": { "type": "string", "default": "none" },
		"metaAlign": { "type": "string", "default": "" },
		"excerptAlign": { "type": "string", "default": "" },
		"buttonAlign": { "type": "string", "default": "" },
		"cardContentAlignment": { "type": "string", "default": "" },
		"cardTitleFontSize": { "type": "integer", "default": 0 },
		"cardTitleFontFamily": { "type": "string", "default": "" },
		"cardTitleFontStyle": { "type": "string", "default": "" },
		"cardTitleFontWeight": { "type": "string", "default": "" },
		"cardTitleLineHeight": { "type": "string", "default": "" },
		"cardTitleLetterSpacing": { "type": "string", "default": "" },
		"cardTitleTextTransform": { "type": "string", "default": "" },
		"cardDateFontSize": { "type": "integer", "default": 0 },
		"cardDateFontFamily": { "type": "string", "default": "" },
		"cardDateFontStyle": { "type": "string", "default": "" },
		"cardDateFontWeight": { "type": "string", "default": "" },
		"cardDateLineHeight": { "type": "string", "default": "" },
		"cardDateLetterSpacing": { "type": "string", "default": "" },
		"cardDateTextTransform": { "type": "string", "default": "" },
		"cardAuthorFontSize": { "type": "integer", "default": 0 },
		"cardAuthorFontFamily": { "type": "string", "default": "" },
		"cardAuthorFontStyle": { "type": "string", "default": "" },
		"cardAuthorFontWeight": { "type": "string", "default": "" },
		"cardAuthorLineHeight": { "type": "string", "default": "" },
		"cardAuthorLetterSpacing": { "type": "string", "default": "" },
		"cardAuthorTextTransform": { "type": "string", "default": "" },
		"cardExcerptFontSize": { "type": "integer", "default": 0 },
		"cardExcerptFontFamily": { "type": "string", "default": "" },
		"cardExcerptFontStyle": { "type": "string", "default": "" },
		"cardExcerptFontWeight": { "type": "string", "default": "" },
		"cardExcerptLineHeight": { "type": "string", "default": "" },
		"cardExcerptLetterSpacing": { "type": "string", "default": "" },
		"cardExcerptTextTransform": { "type": "string", "default": "" },
		"cardButtonFontSize": { "type": "integer", "default": 0 },
		"cardButtonFontFamily": { "type": "string", "default": "" },
		"cardButtonFontStyle": { "type": "string", "default": "" },
		"cardButtonFontWeight": { "type": "string", "default": "" },
		"cardButtonLineHeight": { "type": "string", "default": "" },
		"cardButtonLetterSpacing": { "type": "string", "default": "" },
		"cardButtonTextTransform": { "type": "string", "default": "" },
		"resultsSummaryPosition": { "type": "string", "default": "above_grid" },
		"resultsSummaryColor": { "type": "string", "default": "" },
		"resultsSummaryAlign": { "type": "string", "default": "" },
		"resultsSummaryFontSize": { "type": "integer", "default": 0 },
		"resultsSummaryFontWeight": { "type": "string", "default": "" },
		"resultsSummaryLineHeight": { "type": "string", "default": "" },
		"resultsSummaryFontFamily": { "type": "string", "default": "" },
		"resultsSummaryFontStyle": { "type": "string", "default": "" },
		"resultsSummaryLetterSpacing": { "type": "string", "default": "" },
		"resultsSummaryTextTransform": { "type": "string", "default": "" },
		"paginationPrevText": { "type": "string", "default": "" },
		"paginationNextText": { "type": "string", "default": "" },
		"searchEnabled": { "type": "boolean", "default": false },
		"searchPosition": { "type": "string", "default": "above" },
		"searchAlignment": { "type": "string", "default": "left" },
		"searchField": { "type": "string", "default": "title" },
		"searchStyle": { "type": "string", "default": "branded" },
		"searchInputTextColor": { "type": "string", "default": "" },
		"searchPlaceholderColor": { "type": "string", "default": "" },
		"searchInputBgColor": { "type": "string", "default": "" },
		"searchInputFontSize": { "type": "integer", "default": 0 },
		"searchBorderRadius": { "type": "integer", "default": 0 },
		"searchFocusRingColor": { "type": "string", "default": "" },
		"searchIconColor": { "type": "string", "default": "" },
		"searchBorderColor": { "type": "string", "default": "" },
		"searchBorderWidth": { "type": "integer", "default": 0 },
		"searchShadowColor": { "type": "string", "default": "" },
		"searchShadowIntensity": { "type": "string", "default": "medium" }
	}
}
